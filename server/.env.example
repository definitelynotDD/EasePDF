# Copy to `.env` for local runs. Render uses its dashboard env vars instead.
# None of these are secrets — this app has no API keys or credentials.

PORT=10000

# CORS allow-list (comma-separated). Use your real site in production; "*" for local dev.
ALLOWED_ORIGIN=*

# Upload + processing limits
MAX_FILE_MB=50
MAX_PAGES=50
OCR_DPI=300

# OCR requests per minute, per IP
RATE_LIMIT_MAX=20
